APP_ENV=dev
APP_NAME=ForgePulse

POSTGRES_DB=forgepulse
POSTGRES_USER=forgepulse
POSTGRES_PASSWORD=forgepulse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

PGADMIN_DEFAULT_EMAIL=admin@forgepulse.dev
PGADMIN_DEFAULT_PASSWORD=forgepulse
PGADMIN_PORT=5050

REDIS_HOST=redis
REDIS_PORT=6379

MQTT_HOST=mqtt
MQTT_PORT=1883
MQTT_TELEMETRY_TOPIC=forgepulse/telemetry
MQTT_COMMAND_TOPIC_TEMPLATE=forgepulse/commands/{gateway_id}

EDGE_GATEWAY_ID=EDGE-GW-01
EDGE_LINE_ID=FAB-A-RT
MQTT_COMMAND_TOPIC=forgepulse/commands/EDGE-GW-01
EDGE_PUBLISH_INTERVAL_SECONDS=5
EDGE_PUBLISH_RETRY_COUNT=2
EDGE_SPOOL_FLUSH_LIMIT=20
EDGE_SPOOL_DIR=/tmp/forgepulse-edge-spool

KAFKA_BOOTSTRAP_SERVERS=kafka:9092

API_PORT=8000
WEB_PORT=3000

LLM_PROVIDER=openai-compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
EMBEDDING_MODEL=
